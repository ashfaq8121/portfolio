# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Cloudflare account ID (found in the dashboard)
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token with Workers + D1 permissions
CLOUDFLARE_API_TOKEN=

# Optional: a contact notification email (forwarded via MailChannels or similar)
# CONTACT_NOTIFY_EMAIL=you@example.com
