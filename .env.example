# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Cloudflare account ID (found in the dashboard)
CLOUDFLARE_ACCOUNT_ID=C8da4d3d2a433962e4bba9d3cc26bf686

# Cloudflare API token with Workers + D1 permissions
CLOUDFLARE_API_TOKEN=

# Web3Forms access key for sending contact form emails
# Get yours free at https://web3forms.com
# No setup needed — just enter your email and get a key instantly
WEB3FORMS_ACCESS_KEY=your-access-key-here