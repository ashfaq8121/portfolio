---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  minutesRead?: number;
}

const { title, description, pubDate, slug, tags = [], minutesRead } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}/blog/${slug}`;
---

<article class="blog-card">
  <div class="meta">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    {minutesRead && <span>{minutesRead} min read</span>}
  </div>

  <a href={href} class="title">{title}</a>

  <p class="desc">{description}</p>

  {tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  )}
</article>

<style>
  .blog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
    text-decoration: none;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .meta {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .title {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.3;
  }

  .title:hover {
    color: var(--color-accent);
  }

  .desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tags span {
    padding: var(--space-1) var(--space-2);
    border-radius: 9999px;
    background: var(--color-surface-offset, rgba(0,0,0,0.04));
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }
</style>
