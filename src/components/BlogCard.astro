---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  minutesRead?: number;
  image?: string;
  imageAlt?: string;
}

const { title, description, pubDate, slug, tags = [], minutesRead, image, imageAlt } = Astro.props as Props;

const formattedDate = pubDate.toLocaleDateString("en-IN", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<article class="blog-card">
  <a href={`/blog/${slug}/`} class="blog-link" aria-label={`Read blog post: ${title}`}>
    {image ? (
      <div class="blog-thumb">
        <img
          src={image}
          alt={imageAlt ?? `Cover image for ${title}`}
          loading="lazy"
          decoding="async"
          class="blog-thumb-img"
        />
      </div>
    ) : null}

    <div class="blog-content">
      <div class="blog-meta">
        <span class="blog-date">{formattedDate}</span>
        {minutesRead && <span class="blog-read">{minutesRead} min read</span>}

        {tags.length > 0 && (
          <div class="blog-tags" aria-label="Blog tags">
            {tags.slice(0, 3).map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <h3 class="blog-title">{title}</h3>
      <p class="blog-desc">{description}</p>

      <span class="blog-readmore">Read article →</span>
    </div>
  </a>
</article>

<style>
  .projects-page {
    padding-top: calc(var(--nav-height) + var(--space-10));
    padding-bottom: var(--space-16);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  .page-header {
    max-width: 52rem;
    margin-bottom: var(--space-8);
  }

  .page-header h1 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-2xl);
  }

  .page-lead {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    max-width: 72rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .projects-page {
      padding-top: calc(var(--nav-height) + var(--space-16));
      padding-bottom: var(--space-24);
      padding-left: var(--space-6);
      padding-right: var(--space-6);
    }

    .page-header {
      margin-bottom: var(--space-12);
    }

    .page-header h1 {
      font-size: var(--text-3xl);
    }

    .page-lead {
      font-size: var(--text-base);
    }

    .projects-grid {
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      gap: var(--space-20);
    }
  }
</style>