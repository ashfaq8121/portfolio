---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  minutesRead?: number;
  image?: string;
  imageAlt?: string;
}

const { title, description, pubDate, slug, tags = [], minutesRead, image, imageAlt } = Astro.props as Props;

const formattedDate = pubDate.toLocaleDateString("en-IN", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<article class="blog-card">
<a href={`/blog/${slug.replace(/^\/|\/$/g, '')}/`} class="blog-link" aria-label={`Read blog post: ${title}`}>    {image ? (
      <div class="blog-thumb">
        <img
          src={image}
          alt={imageAlt ?? `Cover image for ${title}`}
          loading="lazy"
          decoding="async"
          class="blog-thumb-img"
        />
      </div>
    ) : null}

    <div class="blog-content">
      <div class="blog-meta">
        <span class="blog-date">{formattedDate}</span>
        {minutesRead && <span class="blog-read">{minutesRead} min read</span>}

        {tags.length > 0 && (
          <div class="blog-tags" aria-label="Blog tags">
            {tags.slice(0, 3).map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <h3 class="blog-title">{title}</h3>
      <p class="blog-desc">{description}</p>

      <span class="blog-readmore">Read article →</span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    height: 100%;
  }

  .blog-card:hover,
  .blog-card:focus-within {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    border-color: var(--color-accent);
  }

  .blog-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .blog-thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
  }

  .blog-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    flex: 1;
  }

  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .blog-date {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .blog-read {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
  }

  .blog-title {
    margin: 0;
    color: var(--color-text);
    font-size: var(--text-lg);
    line-height: 1.35;
    font-weight: 600;
  }

  .blog-desc {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .blog-readmore {
    margin-top: auto;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    padding-top: var(--space-2);
  }

  .blog-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
</style>