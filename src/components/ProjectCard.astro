---
interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  githubUrl?: string;
  liveUrl?: string;
  image?: string;
  screenshotAlt?: string;
  problem: string;
  approach: string;
  result: string;
  nextTime?: string;
}

const {
  title,
  description,
  tags,
  slug,
  githubUrl,
  liveUrl,
  image,
  screenshotAlt,
  problem,
  approach,
  result,
  nextTime,
} = Astro.props as Props;

// Build narration text — include nextTime if present
const narrationParts = [
  `Project: ${title}.`,
  `Problem: ${problem}`,
  `Approach: ${approach}`,
  `Result: ${result}`,
];
if (nextTime) narrationParts.push(`What I'd do next: ${nextTime}`);
const narrationText = narrationParts.join(" ");
---

<article class="project-card" id={slug}>
  <!-- Project image -->
  {image ? (
    <div class="project-image-wrap">
      <img
        src={image}
        alt={screenshotAlt ?? `Screenshot of ${title}`}
        class="project-image"
        loading="lazy"
        decoding="async"
      />
    </div>
  ) : (
    <div class="screenshot-placeholder" role="img" aria-label={`Screenshot of ${title}`}>
      <span class="placeholder-text">Screenshot coming soon</span>
    </div>
  )}

  <!-- Header -->
  <div class="project-card-body">
    {tags.length > 0 && (
      <div class="project-card-tags" aria-label="Technologies used">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}

    <h3 class="project-card-title">{title}</h3>
    <p class="project-card-desc">{description}</p>
  </div>

  <!-- Problem / Approach / Result / Next Time stages -->
  <div class="stages">
    <!-- Voice button -->
    <button
      class="voice-btn"
      aria-label={`Listen to ${title} case study`}
      data-narration={narrationText}
      data-slug={slug}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
      <span class="voice-label">Listen</span>
    </button>

    <div class="stage">
      <span class="stage-label problem-label">Problem</span>
      <p class="stage-text">{problem}</p>
    </div>

    <div class="stage">
      <span class="stage-label approach-label">Approach</span>
      <p class="stage-text">{approach}</p>
    </div>

    <div class="stage">
      <span class="stage-label result-label">Result</span>
      <p class="stage-text">{result}</p>
    </div>

    {nextTime && (
      <div class="stage">
        <span class="stage-label nexttime-label">What I'd Change Next Time</span>
        <p class="stage-text">{nextTime}</p>
      </div>
    )}
  </div>

  <!-- Links -->
  <div class="project-card-links">
    {githubUrl && (
      <a
        href={githubUrl}
        class="btn btn-outline btn-sm"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`GitHub repository for ${title}`}
      >
        View on GitHub &nearr;
      </a>
    )}
    {liveUrl && (
      <a
        href={liveUrl}
        class="btn btn-ghost btn-sm"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Live demo for ${title}`}
      >
        Live demo &nearr;
      </a>
    )}
  </div>
</article>

<!-- Voice narration script — ISLAND for client-side interactivity -->
<script>
  (function () {
    if (typeof window === "undefined" || window.__voiceInit) return;
    window.__voiceInit = true;

    let activeSpeech = null;
    let activeBtn = null;

    function stopSpeech() {
      window.speechSynthesis.cancel();
      if (activeBtn) {
        activeBtn.classList.remove("speaking");
        const label = activeBtn.querySelector(".voice-label");
        if (label) label.textContent = "Listen";
      }
      activeSpeech = null;
      activeBtn = null;
    }

    document.querySelectorAll(".voice-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        // If this button is already speaking, stop it
        if (btn.classList.contains("speaking")) {
          stopSpeech();
          return;
        }

        // Stop any other ongoing speech
        stopSpeech();

        const text = btn.dataset.narration ?? "";
        const utter = new SpeechSynthesisUtterance(text);
        utter.rate = 0.95;
        utter.pitch = 1;
        utter.lang = "en-US";

        utter.onend = () => {
          // Only reset if this is still the active button
          if (activeBtn === btn) {
            btn.classList.remove("speaking");
            const label = btn.querySelector(".voice-label");
            if (label) label.textContent = "Listen";
            activeSpeech = null;
            activeBtn = null;
          }
        };

        utter.onerror = () => {
          if (activeBtn === btn) stopSpeech();
        };

        activeSpeech = utter;
        activeBtn = btn;
        btn.classList.add("speaking");
        const label = btn.querySelector(".voice-label");
        if (label) label.textContent = "Stop";
        window.speechSynthesis.speak(utter);
      });
    });
  })();
</script>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    height: 100%;
    transition:
      box-shadow var(--transition-base),
      border-color var(--transition-base),
      transform var(--transition-base);
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong, var(--color-border));
    transform: translateY(-2px);
  }

  /* ── Image ── */
  .project-image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    aspect-ratio: 16 / 9;
    background: var(--color-surface-offset, rgba(0,0,0,0.03));
  }

  .project-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-image {
    transform: scale(1.02);
  }

  .screenshot-placeholder {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-offset, rgba(0,0,0,0.03));
  }

  .placeholder-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ── Body ── */
  .project-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border-radius: 9999px;
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.05));
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    line-height: 1.2;
  }

  .project-card-title {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: 0;
    color: var(--color-text);
  }

  .project-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Stages ── */
  .stages {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
  }

  .voice-btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .voice-btn:hover {
    background: var(--color-surface-offset, rgba(0,0,0,0.05));
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .voice-btn.speaking {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 40%, transparent); }
    50%       { box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-accent) 0%, transparent); }
  }

  .stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-surface-offset, rgba(0,0,0,0.02));
    border-left: 3px solid transparent;
  }

  .stage:has(.problem-label)   { border-left-color: #ef4444; }
  .stage:has(.approach-label)  { border-left-color: #f59e0b; }
  .stage:has(.result-label)    { border-left-color: #22c55e; }
  .stage:has(.nexttime-label)  { border-left-color: #3b82f6; }

  .stage-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .problem-label   { color: #ef4444; }
  .approach-label  { color: #f59e0b; }
  .result-label    { color: #22c55e; }
  .nexttime-label  { color: #3b82f6; }

  .stage-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Links ── */
  .project-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  .btn-sm {
    padding: 0.375rem var(--space-4);
    font-size: var(--text-xs);
  }
</style>