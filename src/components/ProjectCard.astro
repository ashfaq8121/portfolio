---
interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  githubUrl?: string;
  liveUrl?: string;
  image?: string;
  screenshotAlt?: string;
  problem: string;
  approach: string;
  result: string;
  nextTime?: string;
}

const {
  title,
  description,
  tags,
  slug,
  githubUrl,
  liveUrl,
  image,
  screenshotAlt,
  problem,
  approach,
  result,
  nextTime,
} = Astro.props as Props;

const detailsId = `details-${slug}`;
const buttonId = `toggle-${slug}`;
---

<article class="project-card" id={slug}>
  <button
    id={buttonId}
    class="card-toggle"
    type="button"
    aria-expanded="false"
    aria-controls={detailsId}
  >
    <!-- Image Column -->
    <div class="card-image-col">
      {image ? (
        <div class="card-thumb">
          <img
            src={image}
            alt={screenshotAlt ?? `Screenshot of ${title}`}
            class="card-thumb-img"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : (
        <div
          class="card-thumb card-thumb-placeholder"
          role="img"
          aria-label={`Screenshot of ${title}`}
        >
          <span class="placeholder-icon">📁</span>
        </div>
      )}
    </div>

    <!-- Content Column -->
    <div class="card-content-col">
      {tags.length > 0 && (
        <div class="card-tags" aria-label="Technologies used">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}

      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
    </div>

    <!-- Chevron Column -->
    <div class="card-chevron-col">
      <span class="chevron" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </span>
    </div>
  </button>

  <!-- Hidden Details -->
  <div
    class="card-details"
    id={detailsId}
    role="region"
    aria-labelledby={buttonId}
    hidden
  >
    <div class="stages">
      <div class="stage stage-problem">
        <span class="stage-label">Problem</span>
        <p class="stage-text">{problem}</p>
      </div>

      <div class="stage stage-approach">
        <span class="stage-label">Approach</span>
        <p class="stage-text">{approach}</p>
      </div>

      <div class="stage stage-result">
        <span class="stage-label">Result</span>
        <p class="stage-text">{result}</p>
      </div>

      {nextTime && (
        <div class="stage stage-next">
          <span class="stage-label">What I'd Change Next Time</span>
          <p class="stage-text">{nextTime}</p>
        </div>
      )}
    </div>

    {(githubUrl || liveUrl) && (
      <div class="card-links">
        {githubUrl && (
          <a
            href={githubUrl}
            class="btn btn-outline btn-sm"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`GitHub repository for ${title}`}
          >
            View on GitHub ↗
          </a>
        )}

        {liveUrl && (
          <a
            href={liveUrl}
            class="btn btn-ghost btn-sm"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Live demo for ${title}`}
          >
            Live demo ↗
          </a>
        )}
      </div>
    )}
  </div>
</article>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll(".project-card").forEach((card) => {
      const button = card.querySelector(".card-toggle");
      const detailsId = button?.getAttribute("aria-controls");
      const details = detailsId ? document.getElementById(detailsId) : null;

      if (!button || !details) return;

      button.addEventListener("click", () => {
        const isExpanded = button.getAttribute("aria-expanded") === "true";
        const nextState = !isExpanded;

        button.setAttribute("aria-expanded", String(nextState));
        details.hidden = !nextState;
        card.classList.toggle("is-open", nextState);
      });
    });
  });
</script>

<style>
  /* ===== PROJECT CARD ===== */
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-border-strong, var(--color-border));
    box-shadow: var(--shadow-sm);
  }

  .project-card.is-open {
    border-color: var(--color-border-strong, var(--color-border));
    box-shadow: var(--shadow-md);
  }

  /* ===== TOGGLE BUTTON ===== */
  .card-toggle {
    width: 100%;
    display: flex;
    flex-direction: column;   /* stack vertically on mobile */
    align-items: stretch;
    gap: var(--space-3);
    padding: var(--space-5);
    background: transparent;
    border: 0;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .card-toggle:hover {
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.02));
  }

  .card-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  /* ===== IMAGE COLUMN ===== */
  .card-image-col {
    flex-shrink: 0;
  }

  .card-thumb {
    width: 100%;               /* full width on mobile */
    height: 180px;             /* tall enough to look great */
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.04));
    border: 1px solid var(--color-border);
  }

  .card-thumb-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .card-thumb-placeholder {
    display: grid;
    place-items: center;
    font-size: 1.5rem;
  }

  /* ===== CONTENT + CHEVRON ROW on mobile ===== */
  .card-content-col {
    flex: 1;
    min-width: 0;
    padding-top: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* On mobile, content and chevron sit in a row */
  .card-toggle .card-image-col + .card-content-col {
    flex: 1;
  }

  /* ===== CHEVRON COLUMN ===== */
  .card-chevron-col {
    flex-shrink: 0;
    padding-top: 0;
    align-self: flex-end;       /* sits at bottom-right on mobile */
    display: flex;
    justify-content: flex-end;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1-5);
    margin:5px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.05));
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    line-height: 1.2;
    white-space: nowrap;
  }

  .card-title {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: 1.3;
    font-weight: 600;
    margin:15px;
  }

  .card-desc {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin:15px;
  }

  /* ===== CHEVRON COLUMN ===== */
  .card-chevron-col {
    flex-shrink: 0;
    padding-top: 0;
    align-self: center;
  }

  .chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: transform 0.25s ease, color 0.2s ease;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-md);
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.03));
  }

  .project-card.is-open .chevron {
    transform: rotate(180deg);
    color: var(--color-accent);
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.06));
  }

  /* ===== EXPANDED DETAILS ===== */
  .card-details {
    border-top: 1px solid var(--color-border);
    padding: var(--space-4);
    display: none;
    background: var(--color-surface);
  }

  .card-details:not([hidden]) {
    display: block;
    animation: expandIn 0.3s ease;
  }

  @keyframes expandIn {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .stages {
    display: grid;
    gap: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .stage {
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.02));
    border: 1px solid var(--color-border);
  }

  .stage-problem {
    border-left: 4px solid #ef4444;
  }

  .stage-approach {
    border-left: 4px solid #f59e0b;
  }

  .stage-result {
    border-left: 4px solid #22c55e;
  }

  .stage-next {
    border-left: 4px solid #3b82f6;
  }

  .stage-label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin:20px;
  }

  .stage-problem .stage-label {
    color: #ef4444;
  }

  .stage-approach .stage-label {
    color: #f59e0b;
  }

  .stage-result .stage-label {
    color: #22c55e;
  }

  .stage-next .stage-label {
    color: #3b82f6;
  }

  .stage-text {
    margin: 20px;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .btn-sm {
    min-height: 36px;
    padding: 0.5rem 1rem;
    font-size: var(--text-sm);
    width: -webkit-fill-available;
    justify-content: center;
  
  }

  /* ===== TABLET (640px+) ===== */
  @media (min-width: 640px) {
    .card-toggle {
      flex-direction: row;      /* back to side-by-side on tablet+ */
      align-items: flex-start;
      gap: var(--space-5);
      padding: var(--space-5);
    }

    .card-thumb {
      width: 160px;
      height: 110px;
    }

    .card-thumb-placeholder {
      font-size: 2rem;
    }

    .card-content-col {
      gap: var(--space-3);
      padding-top: var(--space-1);
    }

    .card-chevron-col {
      align-self: center;
      justify-content: center;
    }

    .card-tags {
      gap: var(--space-2);
    }

    .tag {
      padding: 0.25rem 0.75rem;
    }

    .card-title {
      font-size: var(--text-lg);
      margin-left:15px;

    }

    .card-desc {
      font-size: var(--text-sm);
      margin-left:15px;
    }

    .chevron {
      width: 36px;
      height: 36px;
    }

    .card-details {
      padding: var(--space-5);
    }

    .stages {
      gap: var(--space-4);
      margin-bottom: var(--space-5);
    }

    .stage {
      padding: var(--space-5);
    }

    .btn-sm {
      min-height: 40px;
    }
  }

  /* ===== DESKTOP (768px+) ===== */
  @media (min-width: 768px) {
    .card-toggle {
      gap: var(--space-6);
      padding: var(--space-6);
    }

    .card-thumb {
      width: 200px;
      height: 135px;
    }

    .card-title {
      font-size: var(--text-xl);
      mragin-left:25px;
    }

    .card-details {
      padding: var(--space-6);
    }

    .card-links {
      flex-direction: row;
    }

    .card-links a {
        width: -webkit-fill-available;
          justify-content: center;
          margin:10px;
          padding-top:10px;
          border-radius:100px;
    }
  }

  /* ===== LARGE DESKTOP (1024px+) ===== */
  @media (min-width: 1024px) {
    .card-thumb {
      width: 220px;
      height: 150px;
    }

    .card-title {
      font-size: var(--text-xl);
    }
  }
</style>