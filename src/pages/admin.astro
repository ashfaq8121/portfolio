---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Contact Submissions</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #111118;
      --surface-2: #16161f;
      --border: #1f1f2e;
      --border-hover: #2e2e45;
      --accent: #6366f1;
      --accent-hover: #5558e0;
      --accent-glow: rgba(99,102,241,0.12);
      --danger: #ef4444;
      --danger-bg: rgba(239,68,68,0.08);
      --danger-border: rgba(239,68,68,0.2);
      --success: #22c55e;
      --success-bg: rgba(34,197,94,0.08);
      --success-border: rgba(34,197,94,0.2);
      --text: #e2e8f0;
      --text-muted: #64748b;
      --text-dim: #94a3b8;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
      --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 20px 80px;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── LOGIN ─── */
    #login-section {
      width: 100%;
      max-width: 420px;
      margin-top: 8vh;
      animation: fadeUp 0.5s ease both;
    }

    .login-logo {
      text-align: center;
      margin-bottom: 36px;
    }

    .shield {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 60px;
      height: 60px;
      background: var(--accent-glow);
      border: 1.5px solid rgba(99,102,241,0.25);
      border-radius: var(--radius-lg);
      margin-bottom: 18px;
      box-shadow: 0 0 32px var(--accent-glow);
    }

    .login-logo h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.03em;
    }

    .login-logo p {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-top: 6px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 28px;
      box-shadow: var(--shadow-lg);
    }

    .form-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-dim);
      letter-spacing: 0.04em;
      margin-bottom: 10px;
    }

    .input-wrap {
      position: relative;
      margin-bottom: 20px;
    }

    .input-wrap input {
      width: 100%;
      padding: 13px 46px 13px 14px;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md);
      color: var(--text);
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-wrap input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 4px var(--accent-glow);
    }

    .toggle-pw {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-muted);
      padding: 6px;
      display: flex;
      align-items: center;
      border-radius: 6px;
      transition: color 0.2s;
    }
    .toggle-pw:hover { color: var(--text-dim); }

    .btn-login {
      width: 100%;
      padding: 13px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--radius-md);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.2s, transform 0.12s;
      box-shadow: 0 2px 8px rgba(99,102,241,0.3);
    }
    .btn-login:hover { background: var(--accent-hover); }
    .btn-login:active { transform: scale(0.985); }

    .error-msg {
      display: none;
      align-items: center;
      gap: 10px;
      color: var(--danger);
      font-size: 0.875rem;
      margin-top: 16px;
      background: var(--danger-bg);
      border: 1px solid var(--danger-border);
      border-radius: var(--radius-md);
      padding: 12px 14px;
      font-weight: 500;
    }

    /* ─── DASHBOARD ─── */
    #admin-section {
      display: none;
      width: 100%;
      max-width: 1200px;
      animation: fadeUp 0.5s ease both;
    }

    .dash-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .dash-title {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .dash-title h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.02em;
    }

    .badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      background: var(--success-bg);
      color: var(--success);
      border: 1px solid var(--success-border);
    }

    .btn-logout {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 16px;
      background: var(--surface);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md);
      color: var(--text-muted);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
    }
    .btn-logout:hover { border-color: var(--border-hover); color: var(--text-dim); }

    /* Stats */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 20px;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 1.9rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1.1;
    }

    .stat-sub {
      font-size: 0.8rem;
      color: var(--text-dim);
      margin-top: 4px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* ─── DESKTOP TABLE ─── */
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-md);
    }

    .table-toolbar {
      display: flex;
      align-items: center;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }

    .table-toolbar span {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .table-scroll { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }

    thead tr { background: var(--surface-2); }

    th {
      padding: 13px 18px;
      text-align: left;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }

    td {
      padding: 16px 18px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      line-height: 1.6;
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: var(--surface-2); }

    .td-num { color: var(--text-muted); font-size: 0.8rem; font-weight: 600; width: 48px; text-align: center; }
    .td-name { font-weight: 600; color: #fff; white-space: nowrap; }
    .td-email a { color: var(--accent); text-decoration: none; font-weight: 500; }
    .td-email a:hover { text-decoration: underline; }
    .td-message { max-width: 320px; color: var(--text-dim); word-break: break-word; }
    .td-date { white-space: nowrap; color: var(--text-muted); font-size: 0.8rem; }

    .btn-delete {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 7px 12px;
      background: var(--danger-bg);
      border: 1.5px solid var(--danger-border);
      border-radius: var(--radius-sm);
      color: var(--danger);
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .btn-delete:hover {
      background: rgba(239,68,68,0.15);
      border-color: rgba(239,68,68,0.4);
    }

    /* ─── MOBILE CARDS (replaces table on small screens) ─── */
    .mobile-cards { display: none; }

    .submission-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 16px;
      margin-bottom: 12px;
    }

    .card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .card-name {
      font-weight: 700;
      color: #fff;
      font-size: 0.95rem;
    }

    .card-date {
      font-size: 0.72rem;
      color: var(--text-muted);
      white-space: nowrap;
      margin-top: 3px;
    }

    .card-email {
      margin-bottom: 10px;
    }

    .card-email a {
      color: var(--accent);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
    }

    .card-message {
      font-size: 0.875rem;
      color: var(--text-dim);
      line-height: 1.6;
      padding: 10px 12px;
      background: var(--surface-2);
      border-radius: var(--radius-sm);
      margin-bottom: 12px;
      word-break: break-word;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-num {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 600;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }
    .empty-state svg { margin-bottom: 14px; opacity: 0.25; }
    .empty-state p { font-size: 0.95rem; font-weight: 500; }
    .empty-state .empty-sub { font-size: 0.85rem; margin-top: 6px; color: var(--text-dim); }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 20px;
      right: 20px;
      left: auto;
      max-width: 380px;
      padding: 13px 18px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      color: var(--text);
      font-size: 0.875rem;
      font-weight: 500;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: center;
      gap: 10px;
      z-index: 1000;
      animation: toastIn 0.3s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes toastIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #2a2a3e; border-radius: 3px; }

    /* ─── RESPONSIVE BREAKPOINTS ─── */

    /* Tablet */
    @media (max-width: 900px) {
      .stats-row { grid-template-columns: repeat(2, 1fr); }
    }

    /* Mobile */
    @media (max-width: 640px) {
      body { padding: 20px 16px 60px; }

      #login-section { 
        margin-top: 4vh; 
        padding: 0 4px;
      }
      
      .card { padding: 22px 18px; }
      .login-logo h1 { font-size: 1.25rem; }
      .login-logo { margin-bottom: 24px; }
      .shield {
        width: 52px;
        height: 52px;
        margin-bottom: 14px;
      }
      .shield svg { width: 22px; height: 22px; }

      .dash-header { 
        margin-bottom: 16px; 
        gap: 8px;
      }
      .dash-title { gap: 8px; }
      .dash-title h1 { font-size: 1.1rem; }
      .badge { 
        padding: 3px 10px; 
        font-size: 0.75rem; 
      }
      .btn-logout span { display: none; }
      .btn-logout { 
        padding: 8px 10px; 
        border-radius: var(--radius-sm);
      }

      /* Stats: stack to 1 column on mobile */
      .stats-row {
        grid-template-columns: 1fr;
        gap: 10px;
        margin-bottom: 16px;
      }

      .stat-card { 
        padding: 16px; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
      }
      .stat-label { 
        margin-bottom: 0; 
        font-size: 0.7rem;
      }
      .stat-value { 
        font-size: 1.3rem; 
        text-align: left;
      }
      .stat-sub { 
        font-size: 0.72rem; 
        display: block;
      }

      /* Hide desktop table, show cards */
      .table-wrap { display: none; }
      .mobile-cards { 
        display: block; 
        padding: 0 2px;
      }

      .submission-card {
        padding: 16px 14px;
        margin-bottom: 10px;
        border-radius: var(--radius-sm);
      }

      .card-top { margin-bottom: 10px; }
      .card-name { font-size: 0.9rem; }
      .card-date { font-size: 0.7rem; }
      
      .card-email { margin-bottom: 8px; }
      .card-email a { font-size: 0.8rem; }
      
      .card-message {
        font-size: 0.82rem;
        line-height: 1.5;
        padding: 8px 10px;
        margin-bottom: 10px;
      }

      .card-footer { padding-top: 4px; }
      .card-num { font-size: 0.7rem; }
      .btn-delete { padding: 6px 10px; font-size: 0.75rem; }

      /* Toast fix */
      .toast {
        left: 16px;
        right: 16px;
        bottom: 16px;
        max-width: none;
        width: auto;
      }
    }

    /* Extra small screens */
    @media (max-width: 380px) {
      body { padding: 16px 12px 50px; }
      .card { padding: 18px 14px; }
      .login-logo h1 { font-size: 1.15rem; }
      
      .stats-row { gap: 8px; }
      .stat-card { padding: 12px; }
      .stat-value { font-size: 1.2rem; }
      
      .submission-card { padding: 14px 12px; }
      .card-message { font-size: 0.8rem; }
    }
  </style>
</head>
<body>

<!-- ── LOGIN ── -->
<div id="login-section">
  <div class="login-logo">
    <div class="shield">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <h1>Admin Portal</h1>
    <p>Contact submissions dashboard</p>
  </div>
  <div class="card">
    <label class="form-label" for="password">Password</label>
    <div class="input-wrap">
      <input type="password" id="password" placeholder="Enter admin password" autocomplete="current-password" />
      <button class="toggle-pw" type="button" onclick="togglePw()" title="Show/hide password">
        <svg id="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        <svg id="eye-off-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
          <line x1="1" y1="1" x2="23" y2="23"/>
        </svg>
      </button>
    </div>
    <button class="btn-login" onclick="login()">Sign in</button>
    <div class="error-msg" id="login-error">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Incorrect password. Please try again.
    </div>
  </div>
</div>

<!-- ── DASHBOARD ── -->
<div id="admin-section">
  <div class="dash-header">
    <div class="dash-title">
      <h1>Contact Submissions</h1>
      <span class="badge" id="count-badge">0 entries</span>
    </div>
    <button class="btn-logout" onclick="logout()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <span>Logout</span>
    </button>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-label">Total Messages</div>
      <div class="stat-value" id="stat-total">0</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Latest From</div>
      <div class="stat-value" style="font-size:1rem;color:var(--text-dim);padding-top:4px" id="stat-latest">—</div>
      <div class="stat-sub" id="stat-latest-email">No submissions yet</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Latest Date</div>
      <div class="stat-value" style="font-size:0.9rem;color:var(--text-dim);padding-top:4px;line-height:1.4" id="stat-latest-date">—</div>
    </div>
  </div>

  <!-- Desktop Table -->
  <div class="table-wrap">
    <div class="table-toolbar">
      <span id="table-info">All messages</span>
    </div>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th style="text-align:center">#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Message</th>
            <th>Date (UTC)</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="submissions-body">
          <tr><td colspan="6"><div class="empty-state"><p>Loading…</p></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile Cards -->
  <div class="mobile-cards" id="mobile-cards">
    <div class="empty-state"><p>Loading…</p></div>
  </div>
</div>

<script is:inline>
  function togglePw() {
    const input = document.getElementById('password');
    const on = document.getElementById('eye-icon');
    const off = document.getElementById('eye-off-icon');
    if (input.type === 'password') {
      input.type = 'text';
      on.style.display = 'none';
      off.style.display = 'block';
    } else {
      input.type = 'password';
      on.style.display = 'block';
      off.style.display = 'none';
    }
  }

  async function login() {
    const password = document.getElementById('password').value;
    const errEl = document.getElementById('login-error');
    errEl.style.display = 'none';
    const res = await fetch('/api/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password }),
      credentials: 'same-origin'
    });
    if (res.ok) showDashboard();
    else errEl.style.display = 'flex';
  }

  document.getElementById('password').addEventListener('keydown', e => {
    if (e.key === 'Enter') login();
  });

  function showDashboard() {
    document.getElementById('login-section').style.display = 'none';
    document.getElementById('admin-section').style.display = 'block';
    loadSubmissions();
  }

  async function logout() {
    await fetch('/api/admin/logout', { method: 'POST', credentials: 'same-origin' });
    location.reload();
  }

  function formatDate(dateStr) {
    if (!dateStr) return '—';
    try {
      const d = new Date(dateStr);
      return d.toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch { return dateStr; }
  }

  function esc(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function showToast(msg, type) {
    const existing = document.querySelector('.toast');
    if (existing) existing.remove();
    const t = document.createElement('div');
    t.className = 'toast';
    const color = type === 'success' ? '#22c55e' : '#ef4444';
    t.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2"><path d="${type === 'success' ? 'M20 6L9 17l-5-5' : 'M18 6L6 18M6 6l12 12'}"/></svg><span>${msg}</span>`;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3000);
  }

  async function del(id) {
    if (!confirm('Delete this submission?')) return;
    const res = await fetch('/api/admin/submissions?id=' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (res.ok) { showToast('Deleted successfully', 'success'); loadSubmissions(); }
    else showToast('Failed to delete', 'error');
  }

  async function loadSubmissions() {
    const res = await fetch('/api/admin/submissions', { credentials: 'same-origin' });
    if (res.status === 401) { location.reload(); return; }
    const json = await res.json();
    const data = json.data || [];

    // Update stats
    document.getElementById('count-badge').textContent = data.length + ' entr' + (data.length === 1 ? 'y' : 'ies');
    document.getElementById('stat-total').textContent = data.length;
    document.getElementById('stat-latest').textContent = data.length ? esc(data[0].name) : '—';
    document.getElementById('stat-latest-email').textContent = data.length ? esc(data[0].email) : 'No submissions yet';
    document.getElementById('stat-latest-date').textContent = data.length ? formatDate(data[0].submitted_at) : '—';
    document.getElementById('table-info').textContent = data.length ? `Showing ${data.length} message${data.length !== 1 ? 's' : ''}` : 'All messages';

    const emptyHtml = `<div class="empty-state">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <p>No submissions yet</p>
      <p class="empty-sub">Contact form entries will appear here.</p>
    </div>`;

    // Desktop table
    const tbody = document.getElementById('submissions-body');
    if (!data.length) {
      tbody.innerHTML = `<tr><td colspan="6">${emptyHtml}</td></tr>`;
    } else {
      tbody.innerHTML = data.map((row, i) => `
        <tr id="row-${row.id}">
          <td class="td-num">${i + 1}</td>
          <td class="td-name">${esc(row.name)}</td>
          <td class="td-email"><a href="mailto:${esc(row.email)}">${esc(row.email)}</a></td>
          <td class="td-message">${esc(row.message)}</td>
          <td class="td-date">${formatDate(row.submitted_at)}</td>
          <td>
            <button class="btn-delete" onclick="del(${row.id})">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              Delete
            </button>
          </td>
        </tr>
      `).join('');
    }

    // Mobile cards
    const mobileEl = document.getElementById('mobile-cards');
    if (!data.length) {
      mobileEl.innerHTML = emptyHtml;
    } else {
      mobileEl.innerHTML = data.map((row, i) => `
        <div class="submission-card" id="card-${row.id}">
          <div class="card-top">
            <div>
              <div class="card-name">${esc(row.name)}</div>
              <div class="card-date">${formatDate(row.submitted_at)}</div>
            </div>
          </div>
          <div class="card-email">
            <a href="mailto:${esc(row.email)}">${esc(row.email)}</a>
          </div>
          <div class="card-message">${esc(row.message)}</div>
          <div class="card-footer">
            <span class="card-num">#${i + 1}</span>
            <button class="btn-delete" onclick="del(${row.id})">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              Delete
            </button>
          </div>
        </div>
      `).join('');
    }
  }

  // Auto login check
  fetch('/api/admin/submissions', { credentials: 'same-origin' }).then(res => {
    if (res.ok) showDashboard();
  });
</script>

</body>
</html>