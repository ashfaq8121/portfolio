---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

interface Post {
  slug: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    tags: string[];
    minutesRead: number;
    draft?: boolean;
  };
}

const posts: Post[] = [
  {
    slug: "nyc-taxi-dashboard-lessons",
    data: {
      title: "What I Learned from Building an NYC Taxi Dashboard",
      description:
        "A short write-up on how I turned raw taxi trip data into a simple Power BI dashboard with useful business insights.",
      pubDate: new Date("2026-06-01"),
      tags: ["Power BI", "Data Analysis", "Dashboard"],
      minutesRead: 3,
    },
  },
  {
    slug: "sales-dashboard-small-business",
    data: {
      title: "How I Built a Sales Dashboard for Better Business Decisions",
      description:
        "A simple case study on building a Power BI sales dashboard to track profit, products, states, and payment trends.",
      pubDate: new Date("2026-05-30"),
      tags: ["Power BI", "Sales Analytics", "Dashboard"],
      minutesRead: 3,
    },
  },
  {
    slug: "dental-clinic-booking-website",
    data: {
      title: "Building a Simple Dental Clinic Booking Website",
      description:
        "How I created a clean static website that helps patients book appointments and contact the clinic more easily.",
      pubDate: new Date("2026-05-28"),
      tags: ["HTML", "CSS", "JavaScript", "Formspree"],
      minutesRead: 2,
    },
  },
];

const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Short articles based on real projects I have built."
>
  <section class="container blog-page">
    <header class="page-header">
      <div class="header-top">
        <h1>Blog</h1>
        <a href="/rss.xml" class="rss-btn" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1"/>
          </svg>
          Subscribe RSS
        </a>
      </div>
      <p class="page-lead">
        Short and simple write-ups about the projects I built and what I learned from them.
      </p>
    </header>

    {publishedPosts.length === 0 ? (
      <p class="empty-state">No posts yet — check back soon.</p>
    ) : (
      <div class="blog-grid">
        {publishedPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
            minutesRead={post.data.minutesRead}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding-top: calc(var(--nav-height) + var(--space-16));
    padding-bottom: var(--space-24);
  }

  .page-header {
    margin-bottom: var(--space-12);
    max-width: 70rem;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin: 0;
  }

  .rss-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: #f97316;
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: 1px solid #f97316;
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .rss-btn:hover {
    background: #f97316;
    color: white;
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0;
    max-width: 52ch;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 70rem;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  .empty-state {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding-block: var(--space-16);
  }
</style>