---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch — I'm open to work opportunities, collaborations, and interesting conversations."
>
  <div class="container contact-container">
    <div class="contact-layout">

      <!-- ── Info ── -->
      <div class="contact-info">
        <h1>Get in touch</h1>
        <p>
          I'm currently looking for junior software engineering roles.
          If you're hiring, have a project to talk about, or just want
          to say hello — drop me a message.
        </p>
        <p>I usually reply within a day or two.</p>

        <div class="contact-links">
          <a href="https://github.com/ashfaq8121" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/ashfaq-ur-rahman-54832027b" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://wa.me/918121745748" target="_blank" rel="noopener noreferrer" class="contact-link contact-link--whatsapp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="tel:+918121745748" class="contact-link contact-link--phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call me
          </a>
        </div>
      </div>

      <!-- ── Form ── -->
      <div class="contact-form-wrap">

        <!-- Success banner -->
        <div class="alert alert-success" id="form-success" hidden aria-live="polite" role="status">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
          </svg>
          <div>
            <strong>Message sent!</strong>
            <p style="margin:0; font-size: var(--text-sm);">Thanks — I'll get back to you soon.</p>
          </div>
        </div>

        <!-- Error banner -->
        <div class="alert alert-error" id="form-error" hidden aria-live="assertive" role="alert">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <div>
            <strong>Something went wrong</strong>
            <p id="form-error-message" style="margin:0; font-size: var(--text-sm);">Please try again.</p>
          </div>
        </div>

        <form
          id="contact-form"
          class="contact-form"
          action="/api/contact"
          method="POST"
          novalidate
          aria-label="Contact form"
        >
          <!-- Name -->
          <div class="form-group">
            <label class="form-label" for="name">
              Name <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              class="form-input"
              type="text"
              id="name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              aria-describedby="name-error"
            />
            <span class="form-error" id="name-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Email + inline verify -->
          <div class="form-group">
            <label class="form-label" for="email">
              Email <span class="required" aria-hidden="true">*</span>
            </label>
            <div style="display:flex; gap: 8px;">
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                aria-required="true"
                aria-describedby="email-error"
                style="flex:1;"
              />
              <button type="button" id="verify-email-btn" class="btn" style="white-space:nowrap; background:transparent; border:1px solid var(--color-border, #333);">
                Verify email
              </button>
            </div>
            <span class="form-error" id="email-error" role="alert" aria-live="polite"></span>

            <!-- Inline OTP box — hidden until "Verify email" is clicked -->
            <div id="otp-inline" hidden style="margin-top: 10px; padding: 12px; border: 1px solid var(--color-border, #333); border-radius: 10px;">
              <p style="margin: 0 0 8px 0; font-size: 0.875rem; opacity: 0.8;">
                Enter the 6-digit code sent to <strong id="otp-email-display"></strong>
              </p>
              <div style="display:flex; gap: 8px; align-items:flex-start;">
                <input
                  class="form-input"
                  type="text"
                  id="otp-code"
                  inputmode="numeric"
                  maxlength="6"
                  autocomplete="one-time-code"
                  placeholder="000000"
                  style="flex:1;"
                />
                <button type="button" id="confirm-otp-btn" class="btn btn-primary" style="white-space:nowrap;">
                  Confirm
                </button>
              </div>
              <span class="form-error" id="otp-error" role="alert" aria-live="polite" style="display:block; margin-top: 4px;"></span>
            </div>

            <!-- Verified confirmation badge -->
            <p id="email-verified-badge" hidden style="margin-top: 8px; font-size: 0.875rem; color: #22c55e; display:flex; align-items:center; gap: 6px;">
              ✓ Email verified
            </p>
          </div>

          <!-- Message — disabled until email is verified -->
          <div class="form-group">
            <label class="form-label" for="message">
              Message <span class="required" aria-hidden="true">*</span>
            </label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              rows="6"
              required
              disabled
              aria-required="true"
              aria-describedby="message-error"
              placeholder="Verify your email above to write your message"
            ></textarea>
            <span class="form-error" id="message-error" role="alert" aria-live="polite"></span>
          </div>

          <button type="submit" class="btn btn-primary btn-submit" id="submit-btn" disabled>
            <span class="btn-text">Send message</span>
            <span class="btn-spinner" aria-hidden="true" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
              Sending…
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
  }

  .contact-link:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .contact-link--whatsapp:hover {
    color: #25D366;
    border-color: #25D366;
  }

  .contact-link--phone:hover {
    color: #0ea5e9;
    border-color: #0ea5e9;
  }

  .contact-container {
    padding-top: calc(var(--nav-height) + var(--space-16));
    padding-bottom: var(--space-24);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-info h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
    line-height: 1.1;
  }

  .contact-info p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 38ch;
    margin-bottom: var(--space-4);
  }

  .contact-links {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-form-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .btn-submit { align-self: flex-start; min-width: 10rem; }
  .btn-spinner svg { animation: spin 0.7s linear infinite; }

  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  const form = document.getElementById("contact-form");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const btnText = submitBtn?.querySelector(".btn-text") as HTMLElement | null;
  const btnSpinner = submitBtn?.querySelector(".btn-spinner") as HTMLElement | null;
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");
  const errorMsg = document.getElementById("form-error-message");

  const emailInput = document.getElementById("email") as HTMLInputElement | null;
  const verifyBtn = document.getElementById("verify-email-btn") as HTMLButtonElement | null;
  const otpInline = document.getElementById("otp-inline");
  const otpEmailDisplay = document.getElementById("otp-email-display");
  const otpInput = document.getElementById("otp-code") as HTMLInputElement | null;
  const otpError = document.getElementById("otp-error");
  const confirmOtpBtn = document.getElementById("confirm-otp-btn") as HTMLButtonElement | null;
  const verifiedBadge = document.getElementById("email-verified-badge");
  const messageInput = document.getElementById("message") as HTMLTextAreaElement | null;

  let verifiedEmail: string | null = null;

  function setFieldError(fieldId: string, message: string) {
    const input = document.getElementById(fieldId);
    const span = document.getElementById(`${fieldId}-error`);
    if (input) input.setAttribute("aria-invalid", message ? "true" : "false");
    if (span) span.textContent = message;
  }

  function clearErrors() {
    ["name", "email", "message"].forEach((id) => setFieldError(id, ""));
  }

  function setLoading(on: boolean) {
    if (submitBtn) submitBtn.disabled = on || !verifiedEmail;
    if (btnText) btnText.hidden = on;
    if (btnSpinner) btnSpinner.hidden = !on;
  }

  function lockMessageField(unlocked: boolean) {
    if (messageInput) {
      messageInput.disabled = !unlocked;
      messageInput.placeholder = unlocked ? "" : "Verify your email above to write your message";
    }
    if (submitBtn) submitBtn.disabled = !unlocked;
  }

  function isGmail(email: string) {
    return /^[^\s@]+@gmail\.com$/i.test(email);
  }

  // ── "Verify email" button: sends the OTP ──
  verifyBtn?.addEventListener("click", async () => {
    setFieldError("email", "");
    const email = emailInput?.value?.trim() ?? "";

    if (!email) { setFieldError("email", "Email is required."); return; }
    if (!isGmail(email)) { setFieldError("email", "Only Gmail addresses are accepted (e.g. yourname@gmail.com)."); return; }

    verifyBtn.disabled = true;
    verifyBtn.textContent = "Sending…";

    try {
      const res = await fetch("/api/contact/send-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });
      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok) {
        if (otpInline) (otpInline as HTMLElement).hidden = false;
        if (otpEmailDisplay) otpEmailDisplay.textContent = email;
        if (emailInput) emailInput.disabled = true; // lock email while verifying
        otpInput?.focus();
      } else {
        setFieldError("email", body.error ?? "Could not send verification code.");
      }
    } catch {
      setFieldError("email", "Could not reach the server. Please check your connection.");
    } finally {
      verifyBtn.disabled = false;
      verifyBtn.textContent = "Verify email";
    }
  });

  // ── "Confirm" button: checks the OTP, unlocks the message field ──
  confirmOtpBtn?.addEventListener("click", async () => {
    if (otpError) otpError.textContent = "";
    const email = emailInput?.value?.trim() ?? "";
    const otp = otpInput?.value?.trim() ?? "";

    if (!otp) { if (otpError) otpError.textContent = "Please enter the code from your email."; return; }

    confirmOtpBtn.disabled = true;
    confirmOtpBtn.textContent = "Checking…";

    try {
      const res = await fetch("/api/contact/verify-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, otp }),
      });
      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok) {
        verifiedEmail = email;
        if (otpInline) (otpInline as HTMLElement).hidden = true;
        if (verifyBtn) (verifyBtn as HTMLElement).hidden = true;
        if (verifiedBadge) (verifiedBadge as HTMLElement).hidden = false;
        lockMessageField(true);
        messageInput?.focus();
      } else {
        if (otpError) otpError.textContent = body.error ?? "Incorrect code. Please try again.";
      }
    } catch {
      if (otpError) otpError.textContent = "Could not reach the server. Please check your connection.";
    } finally {
      confirmOtpBtn.disabled = false;
      confirmOtpBtn.textContent = "Confirm";
    }
  });

  // If the user edits the email after verifying, they must verify again.
  emailInput?.addEventListener("input", () => {
    if (verifiedEmail && emailInput.value.trim() !== verifiedEmail) {
      verifiedEmail = null;
      if (verifiedBadge) (verifiedBadge as HTMLElement).hidden = true;
      if (verifyBtn) (verifyBtn as HTMLElement).hidden = false;
      lockMessageField(false);
    }
  });

  function validate(data: { name: string; email: string; message: string }) {
    const errors: Record<string, string> = {};
    if (data.name.trim().length < 2) errors.name = "Please enter your name (at least 2 characters).";
    if (data.message.trim().length < 10) errors.message = "Please enter a message (at least 10 characters).";
    return errors;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();
    if (successEl) successEl.hidden = true;
    if (errorEl) errorEl.hidden = true;

    if (!verifiedEmail) {
      setFieldError("email", "Please verify your email first.");
      return;
    }

    const data = {
      name: (document.getElementById("name") as HTMLInputElement)?.value?.trim() ?? "",
      email: verifiedEmail,
      message: messageInput?.value?.trim() ?? "",
    };

    const errors = validate(data);
    if (Object.keys(errors).length > 0) {
      Object.entries(errors).forEach(([field, msg]) => setFieldError(field, msg));
      document.getElementById(Object.keys(errors)[0])?.focus();
      return;
    }

    setLoading(true);

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok) {
        (form as HTMLFormElement).reset();
        verifiedEmail = null;
        if (emailInput) emailInput.disabled = false;
        if (verifiedBadge) (verifiedBadge as HTMLElement).hidden = true;
        if (verifyBtn) (verifyBtn as HTMLElement).hidden = false;
        lockMessageField(false);
        if (successEl) successEl.hidden = false;
      } else {
        if (errorMsg) errorMsg.textContent = body.error ?? "Something went wrong. Please try again.";
        if (errorEl) errorEl.hidden = false;
      }
    } catch {
      if (errorMsg) errorMsg.textContent = "Could not reach the server. Please check your connection.";
      if (errorEl) errorEl.hidden = false;
    } finally {
      setLoading(false);
    }
  });
</script>