---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch — I'm open to work opportunities, collaborations, and interesting conversations."
>
  <div class="container contact-container">
    <div class="contact-layout">

      <!-- ── Info ── -->
      <div class="contact-info">
        <h1>Get in touch</h1>
        <p>
          I'm currently looking for junior software engineering roles.
          If you're hiring, have a project to talk about, or just want
          to say hello — drop me a message.
        </p>
        <p>I usually reply within a day or two.</p>

        <div class="contact-links">
          <a href="https://github.com/ashfaq8121" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/ashfaq-ur-rahman-54832027b" target="_blank" rel="noopener noreferrer" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://wa.me/918121745748" target="_blank" rel="noopener noreferrer" class="contact-link contact-link--whatsapp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="tel:+918121745748" class="contact-link contact-link--phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call me
          </a>
        </div>
      </div>

      <!-- ── Form ── -->
      <div class="contact-form-wrap">

        <!-- Success banner -->
        <div class="alert alert-success" id="form-success" hidden aria-live="polite" role="status">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
          </svg>
          <div>
            <strong>Message sent!</strong>
            <p style="margin:0; font-size: var(--text-sm);">Thanks — I'll get back to you soon.</p>
          </div>
        </div>

        <!-- Error banner -->
        <div class="alert alert-error" id="form-error" hidden aria-live="assertive" role="alert">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <div>
            <strong>Something went wrong</strong>
            <p id="form-error-message" style="margin:0; font-size: var(--text-sm);">Please try again.</p>
          </div>
        </div>

        <form
          id="contact-form"
          class="contact-form"
          novalidate
          aria-label="Contact form"
        >
          <!-- Name -->
          <div class="form-group">
            <label class="form-label" for="name">
              Name <span class="required" aria-hidden="true">*</span>
            </label>
            <input
              class="form-input"
              type="text"
              id="name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              aria-describedby="name-error"
            />
            <span class="form-error" id="name-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Email — step 1: enter + request a code -->
          <div class="form-group" id="email-step">
            <label class="form-label" for="email">
              Email (Gmail only) <span class="required" aria-hidden="true">*</span>
            </label>
            <div class="inline-field">
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                placeholder="yourname@gmail.com"
                required
                aria-required="true"
                aria-describedby="email-error"
              />
              <button type="button" class="btn btn-secondary btn-inline" id="send-otp-btn">
                Send code
              </button>
            </div>
            <span class="form-error" id="email-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- OTP — step 2: enter the code that was emailed -->
          <div class="form-group" id="otp-step" hidden>
            <label class="form-label" for="otp">Verification code</label>
            <div class="inline-field">
              <input
                class="form-input"
                type="text"
                id="otp"
                name="otp"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="6"
                placeholder="6-digit code"
                aria-describedby="otp-error"
              />
              <button type="button" class="btn btn-secondary btn-inline" id="verify-otp-btn">
                Verify
              </button>
            </div>
            <div class="otp-meta">
              <span id="otp-timer" class="otp-timer"></span>
              <span class="otp-meta-actions">
                <button type="button" class="link-btn" id="resend-otp-btn">Resend code</button>
                <span aria-hidden="true">·</span>
                <button type="button" class="link-btn" id="change-email-btn">Change email</button>
              </span>
            </div>
            <span class="form-error" id="otp-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Verified badge — shown once OTP succeeds -->
          <div class="verified-badge" id="verified-badge" hidden>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
            </svg>
            <span><span id="verified-email-text"></span> verified</span>
            <button type="button" class="link-btn" id="use-different-email-btn">Use a different email</button>
          </div>

          <!-- Message — unlocked only after email is verified -->
          <div class="form-group" id="message-step" hidden>
            <label class="form-label" for="message">
              Message <span class="required" aria-hidden="true">*</span>
            </label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              rows="6"
              required
              aria-required="true"
              aria-describedby="message-error"
            ></textarea>
            <span class="form-error" id="message-error" role="alert" aria-live="polite"></span>
          </div>

          <button type="submit" class="btn btn-primary btn-submit" id="submit-btn" hidden>
            <span class="btn-text">Send message</span>
            <span class="btn-spinner" aria-hidden="true" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
              Sending…
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
  }

  .contact-link:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .contact-link--whatsapp:hover {
    color: #25D366;
    border-color: #25D366;
  }

  .contact-link--phone:hover {
    color: #0ea5e9;
    border-color: #0ea5e9;
  }

  .contact-container {
    padding-top: calc(var(--nav-height) + var(--space-16));
    padding-bottom: var(--space-24);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-info h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
    line-height: 1.1;
  }

  .contact-info p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 38ch;
    margin-bottom: var(--space-4);
  }

  .contact-links {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-form-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .btn-submit { align-self: flex-start; min-width: 10rem; }
  .btn-spinner svg { animation: spin 0.7s linear infinite; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .inline-field {
    display: flex;
    gap: var(--space-2);
  }

  .inline-field .form-input { flex: 1; }

  .btn-inline {
    white-space: nowrap;
    flex-shrink: 0;
  }

  .btn-secondary {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-lg);
    padding: 0 var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-secondary:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-secondary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .otp-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  .otp-timer {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .otp-meta-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .link-btn {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
  }

  .link-btn:hover { opacity: 0.8; }
  .link-btn:disabled { opacity: 0.5; cursor: not-allowed; text-decoration: none; }

  .verified-badge {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
  }

  .verified-badge svg { color: #16a34a; flex-shrink: 0; }
  .verified-badge .link-btn { margin-left: auto; }

  /* The hidden attribute must always win over our own display rules above —
     otherwise elements like .verified-badge stay visible even when hidden
     is set by JS, since author CSS overrides the browser's default. */
  [hidden] { display: none !important; }
</style>

<script>
  const form = document.getElementById("contact-form");
  const submitBtn = document.getElementById("submit-btn");
  const btnText = submitBtn?.querySelector(".btn-text");
  const btnSpinner = submitBtn?.querySelector(".btn-spinner");
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");
  const errorMsg = document.getElementById("form-error-message");

  const emailStep = document.getElementById("email-step");
  const emailInput = document.getElementById("email");
  const sendOtpBtn = document.getElementById("send-otp-btn");

  const otpStep = document.getElementById("otp-step");
  const otpInput = document.getElementById("otp");
  const verifyOtpBtn = document.getElementById("verify-otp-btn");
  const resendOtpBtn = document.getElementById("resend-otp-btn");
  const changeEmailBtn = document.getElementById("change-email-btn");
  const otpTimerEl = document.getElementById("otp-timer");
  const otpErrorEl = document.getElementById("otp-error");

  const verifiedBadge = document.getElementById("verified-badge");
  const verifiedEmailText = document.getElementById("verified-email-text");
  const useDifferentEmailBtn = document.getElementById("use-different-email-btn");

  const messageStep = document.getElementById("message-step");

  let otpTimerInterval: ReturnType<typeof setInterval> | null = null;
  let otpExpiresAt = 0;
  let verifiedEmail: string | null = null;

  function setFieldError(fieldId: string, message: string) {
    const input = document.getElementById(fieldId);
    const span = document.getElementById(`${fieldId}-error`);
    if (input) input.setAttribute("aria-invalid", message ? "true" : "false");
    if (span) span.textContent = message;
  }

  function clearErrors() {
    ["name", "email", "message"].forEach((id) => setFieldError(id, ""));
  }

  function setLoading(on: boolean) {
    if (submitBtn) (submitBtn as HTMLButtonElement).disabled = on;
    if (btnText) (btnText as HTMLElement).hidden = on;
    if (btnSpinner) (btnSpinner as HTMLElement).hidden = !on;
  }

  // ── OTP countdown ──────────────────────────────────────────────────────
  function startOtpTimer(seconds: number) {
    if (otpTimerInterval) clearInterval(otpTimerInterval);
    otpExpiresAt = Date.now() + seconds * 1000;
    (otpInput as HTMLInputElement).disabled = false;
    (verifyOtpBtn as HTMLButtonElement).disabled = false;
    updateOtpTimerDisplay();
    otpTimerInterval = setInterval(updateOtpTimerDisplay, 1000);
  }

  function updateOtpTimerDisplay() {
    const remaining = Math.max(0, Math.round((otpExpiresAt - Date.now()) / 1000));
    const m = Math.floor(remaining / 60);
    const s = remaining % 60;
    if (otpTimerEl) otpTimerEl.textContent = `Code expires in ${m}:${s.toString().padStart(2, "0")}`;
    if (remaining <= 0) {
      if (otpTimerInterval) clearInterval(otpTimerInterval);
      if (otpTimerEl) otpTimerEl.textContent = "Code expired — request a new one.";
      (otpInput as HTMLInputElement).disabled = true;
      (verifyOtpBtn as HTMLButtonElement).disabled = true;
    }
  }

  // ── Step transitions ───────────────────────────────────────────────────
  function showOtpStep() {
    (emailInput as HTMLInputElement).disabled = true;
    (sendOtpBtn as HTMLButtonElement).disabled = true;
    if (otpStep) (otpStep as HTMLElement).hidden = false;
    if (otpInput) (otpInput as HTMLInputElement).value = "";
    if (otpErrorEl) otpErrorEl.textContent = "";
    otpInput?.focus();
  }

  function showVerified(email: string) {
    verifiedEmail = email;
    if (otpTimerInterval) clearInterval(otpTimerInterval);
    if (emailStep) (emailStep as HTMLElement).hidden = true;
    if (otpStep) (otpStep as HTMLElement).hidden = true;
    if (verifiedBadge) (verifiedBadge as HTMLElement).hidden = false;
    if (verifiedEmailText) verifiedEmailText.textContent = email;
    if (messageStep) (messageStep as HTMLElement).hidden = false;
    if (submitBtn) (submitBtn as HTMLElement).hidden = false;
  }

  function resetToEmailStep() {
    verifiedEmail = null;
    if (otpTimerInterval) clearInterval(otpTimerInterval);
    if (emailStep) (emailStep as HTMLElement).hidden = false;
    (emailInput as HTMLInputElement).disabled = false;
    (sendOtpBtn as HTMLButtonElement).disabled = false;
    if (otpStep) (otpStep as HTMLElement).hidden = true;
    if (verifiedBadge) (verifiedBadge as HTMLElement).hidden = true;
    if (messageStep) (messageStep as HTMLElement).hidden = true;
    if (submitBtn) (submitBtn as HTMLElement).hidden = true;
    setFieldError("otp", "");
    otpInput?.focus();
  }

  // ── Request a code (also used for "Resend") ───────────────────────────
  async function requestOtp() {
    const email = (emailInput as HTMLInputElement).value.trim();
    setFieldError("email", "");

    if (!/^[^\s@]+@gmail\.com$/i.test(email)) {
      setFieldError("email", "Please enter a valid Gmail address.");
      return;
    }

    (sendOtpBtn as HTMLButtonElement).disabled = true;
    if (resendOtpBtn) (resendOtpBtn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch("/api/contact/request-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
        credentials: "same-origin",
      });
      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok && body.alreadyVerified) {
        showVerified(email);
        return;
      }
      if (res.ok && body.ok) {
        showOtpStep();
        startOtpTimer(body.expiresInSeconds ?? 120);
        return;
      }
      setFieldError("email", body.error ?? "Could not send the code. Please try again.");
    } catch {
      setFieldError("email", "Could not reach the server. Please check your connection.");
    } finally {
      (sendOtpBtn as HTMLButtonElement).disabled = false;
      if (resendOtpBtn) (resendOtpBtn as HTMLButtonElement).disabled = false;
    }
  }

  // ── Verify the entered code ────────────────────────────────────────────
  async function verifyOtp() {
    const email = (emailInput as HTMLInputElement).value.trim();
    const otp = (otpInput as HTMLInputElement).value.trim();
    if (otpErrorEl) otpErrorEl.textContent = "";

    if (!otp) {
      if (otpErrorEl) otpErrorEl.textContent = "Please enter the code.";
      return;
    }

    (verifyOtpBtn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch("/api/contact/verify-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, otp }),
        credentials: "same-origin",
      });
      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok) {
        showVerified(email);
        return;
      }

      if (otpErrorEl) otpErrorEl.textContent = body.error ?? "Incorrect code.";
      if (body.expired || body.lockedOut) {
        (otpInput as HTMLInputElement).disabled = true;
        return; // leave verify button disabled — must resend or wait out lockout
      }
    } catch {
      if (otpErrorEl) otpErrorEl.textContent = "Could not reach the server. Please check your connection.";
    }

    (verifyOtpBtn as HTMLButtonElement).disabled = false;
  }

  sendOtpBtn?.addEventListener("click", requestOtp);
  resendOtpBtn?.addEventListener("click", requestOtp);
  verifyOtpBtn?.addEventListener("click", verifyOtp);
  changeEmailBtn?.addEventListener("click", resetToEmailStep);
  useDifferentEmailBtn?.addEventListener("click", resetToEmailStep);

  otpInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      verifyOtp();
    }
  });

  emailInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      requestOtp();
    }
  });

  // ── Final submit — only reachable once verifiedEmail is set ───────────
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();
    if (successEl) (successEl as HTMLElement).hidden = true;
    if (errorEl) (errorEl as HTMLElement).hidden = true;

    if (!verifiedEmail) {
      if (errorMsg) errorMsg.textContent = "Please verify your email first.";
      if (errorEl) (errorEl as HTMLElement).hidden = false;
      return;
    }

    const data = {
      name: (document.getElementById("name") as HTMLInputElement)?.value?.trim() ?? "",
      email: verifiedEmail,
      message: (document.getElementById("message") as HTMLTextAreaElement)?.value?.trim() ?? "",
    };

    const errors: Record<string, string> = {};
    if (data.name.trim().length < 2) errors.name = "Please enter your name (at least 2 characters).";
    if (data.message.trim().length < 10) errors.message = "Please enter a message (at least 10 characters).";

    if (Object.keys(errors).length > 0) {
      Object.entries(errors).forEach(([field, msg]) => setFieldError(field, msg));
      document.getElementById(Object.keys(errors)[0])?.focus();
      return;
    }

    setLoading(true);

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
        credentials: "same-origin",
      });

      const body = await res.json().catch(() => ({}));

      if (res.ok && body.ok) {
        (form as HTMLFormElement).reset();
        resetToEmailStep();
        if (successEl) (successEl as HTMLElement).hidden = false;
      } else {
        const firstFieldError = body.errors ? Object.values(body.errors)[0] : null;
        if (errorMsg) errorMsg.textContent = body.error ?? firstFieldError ?? "Something went wrong. Please try again.";
        if (errorEl) (errorEl as HTMLElement).hidden = false;
      }
    } catch {
      if (errorMsg) errorMsg.textContent = "Could not reach the server. Please check your connection.";
      if (errorEl) (errorEl as HTMLElement).hidden = false;
    } finally {
      setLoading(false);
    }
  });
</script>