---
// src/pages/ask.astro
// Adjust this import to match whatever layout your other pages use
// (contact.astro / about.astro etc.) — copy their exact import line if different.
import BaseLayout from "../layouts/BaseLayout.astro";

// Per-request nonce set by src/middleware.ts, allow-listed in that same
// request's Content-Security-Policy header. Passed to this page's own
// <script> tag below so the browser will actually execute it instead of
// blocking it as an unauthorized inline script.
//
// NOTE: if the chat buttons still don't respond after this fix, check that
// middleware.ts is still setting Astro.locals.cspNonce correctly — that
// file wasn't part of this fix pass, and if it's empty/undefined here the
// script below will get silently blocked by CSP with no visible error.
const nonce = Astro.locals.cspNonce as string;
---
<BaseLayout title="Ask About Me — Ashfaq ur Rahman" description="Browse questions about Ashfaq's background, grounded in his real résumé.">
  <section class="ask-section">
    <div class="ask-intro">
      <h1>Ask About Me</h1>
      <p>
        Pick a category below, then a question — I'll answer instantly from my real résumé.
        You can also type your own question if you don't see what you're looking for.
      </p>
      <a href="/ashfaq-ur-rahman-resume.pdf" download class="resume-download-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Résumé (PDF)
      </a>
    </div>

    <div class="chat-card">
      <div class="menu-area" id="menu-area"></div>

      <div id="chat-log" class="chat-log" aria-live="polite"></div>

      <form id="chat-form" class="chat-form">
        <input
          type="text"
          id="chat-input"
          class="chat-input"
          placeholder="Or type your own question..."
          autocomplete="off"
          maxlength="500"
          required
        />
        <button type="submit" class="btn btn-primary chat-send-btn" id="chat-send-btn">
          Ask
        </button>
      </form>
      <span class="chat-error" id="chat-error" role="alert" aria-live="polite"></span>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /*
   * is:global on purpose: the menu buttons and chat bubbles below are
   * created dynamically with document.createElement() in the <script> tag.
   * Astro's normal scoped styles only attach their scoping attribute to
   * elements present in this file's template at build time — anything
   * created later in plain JS never gets that attribute, so scoped rules
   * silently fail to match them (this is why buttons rendered as plain
   * unstyled text before). Going global avoids that trap. Class names
   * below are specific enough that collisions with other pages are very
   * unlikely, but rename them if you ever see a clash.
   */

  .ask-section {
    max-width: 720px;
    margin: 0 auto;
    /* max() guarantees clearance below a fixed/sticky nav regardless of
       its exact height, instead of guessing a fixed padding value. */
    padding-top: max(var(--space-8, 2rem), 6rem);
    padding-bottom: var(--space-8, 2rem);
    padding-left: var(--space-4, 1rem);
    padding-right: var(--space-4, 1rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-6, 1.5rem);
  }

  .ask-intro h1 { margin-bottom: var(--space-2, 0.5rem); }
  .ask-intro p { color: var(--color-text-secondary, #9a9a9a); line-height: 1.6; }

  .resume-download-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    margin-top: var(--space-3, 0.75rem);
    padding: var(--space-2, 0.5rem) var(--space-4, 1rem);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface, #1a1a1a);
    color: var(--color-text, #eaeaea);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .resume-download-btn:hover {
    border-color: var(--color-accent, #6366f1);
    color: var(--color-accent, #6366f1);
  }

  .chat-card {
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface, #1a1a1a);
    padding: var(--space-4, 1rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  /* ── Category / subcategory menu ── */
  .menu-area {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  .menu-heading {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-text, #eaeaea);
  }

  .back-btn {
    background: none;
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text, #eaeaea);
    cursor: pointer;
    flex-shrink: 0;
  }

  .back-btn:hover { border-color: var(--color-accent, #6366f1); color: var(--color-accent, #6366f1); }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-2, 0.5rem);
  }

  .menu-btn {
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    padding: var(--space-3, 0.75rem);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    color: var(--color-text, #eaeaea);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }

  .menu-btn:hover:not(:disabled) {
    border-color: var(--color-accent, #6366f1);
    color: var(--color-accent, #6366f1);
  }

  .menu-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .menu-btn.category {
    font-weight: 600;
    text-align: center;
    padding: var(--space-4, 1rem);
  }

  /* ── Chat log ── */
  .chat-log {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    min-height: 8rem;
    max-height: 24rem;
    overflow-y: auto;
    padding: var(--space-2, 0.5rem);
  }

  .chat-msg {
    max-width: 85%;
    padding: var(--space-3, 0.75rem);
    border-radius: var(--radius-lg, 12px);
    line-height: 1.5;
    font-size: var(--text-sm, 0.875rem);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .chat-msg.user {
    align-self: flex-end;
    background: var(--color-accent, #6366f1);
    color: #ffffff;
  }

  .chat-msg.bot {
    align-self: flex-start;
    background: var(--color-bg, #111);
    color: var(--color-text, #eaeaea);
    border: 1px solid var(--color-border, #333);
  }

  .chat-msg.bot.not-found {
    background: transparent;
    border-style: dashed;
    color: var(--color-text-secondary, #9a9a9a);
    font-style: italic;
  }

  .chat-msg.bot.pending {
    color: var(--color-text-secondary, #9a9a9a);
    font-style: italic;
    animation: chat-pending-pulse 1.2s ease-in-out infinite;
  }

  @keyframes chat-pending-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .chat-form {
    display: flex;
    gap: var(--space-2, 0.5rem);
  }

  .chat-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-3, 0.75rem);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-bg, #111);
    color: var(--color-text, #eaeaea);
    font-size: var(--text-sm, 0.875rem);
  }

  .chat-send-btn { white-space: nowrap; }

  .chat-error {
    color: #f87171;
    font-size: var(--text-sm, 0.875rem);
  }

  /* ── Mobile responsiveness ── */
  @media (max-width: 480px) {
    .ask-section {
      padding-top: max(var(--space-6, 1.5rem), 5rem);
      gap: var(--space-4, 1rem);
    }

    .menu-grid {
      grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
      gap: var(--space-2, 0.5rem);
    }

    .menu-btn { padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem); }
    .menu-btn.category { padding: var(--space-3, 0.75rem); }

    /* Stack input + button instead of squeezing them side by side —
       keeps both comfortably tappable on a phone screen. */
    .chat-form {
      flex-direction: column;
    }

    .chat-send-btn {
      width: 100%;
    }

    .chat-msg {
      max-width: 100%;
    }

    .chat-log {
      max-height: 20rem;
    }

    .resume-download-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
<script nonce={nonce}>
  // NOTE: plain JS on purpose — this runs directly in the browser with no
  // build-time type stripping applied to inline <script> content, so any
  // TypeScript syntax here (type aliases, generics, `as` casts) throws a
  // SyntaxError before a single line runs, silently killing the whole
  // widget. If you want real type-checking for this logic, write it in a
  // separate .ts file under src/scripts and import it with <script src>,
  // which Vite *will* type-strip.
  (function () {
    // ── Category tree ──
    var CATEGORY_TREE = {
      "Education": [
        { label: "B.Tech (Computer Science)", question: "Tell me about Ashfaq's B.Tech degree." },
        { label: "Intermediate (12th Grade)", question: "What did Ashfaq score in his Intermediate (12th grade)?" },
        { label: "SSC (10th Grade)", question: "What did Ashfaq score in his SSC (10th grade)?" },
      ],
      "Skills": [
        { label: "Programming Languages", question: "What programming languages does Ashfaq know?" },
        { label: "BI & Dashboard Tools", question: "What BI or dashboard tools has Ashfaq used?" },
        { label: "Data Analysis Skills", question: "What data analysis skills does Ashfaq have?" },
        { label: "Web Technologies", question: "What web technologies does Ashfaq know?" },
      ],
      "Projects": [
        { label: "Superstore Sales Analysis", question: "Tell me about Ashfaq's Superstore Sales Analysis project." },
        { label: "NYC Taxi Data Dashboard", question: "Tell me about Ashfaq's NYC taxi project." },
        { label: "HR Attrition Analysis", question: "Tell me about Ashfaq's HR Attrition Analysis project." },
      ],
      "Certifications": [
        { label: "Google Analytics", question: "Tell me about Ashfaq's Google Analytics certification." },
        { label: "Power BI (Microsoft Learn)", question: "Tell me about Ashfaq's Power BI certification." },
        { label: "Python Internship Certificate", question: "Tell me about Ashfaq's Python programming internship certification." },
      ],
      "Other": [
        { label: "Internships", question: "What internships has Ashfaq completed?" },
        { label: "Achievements", question: "What are Ashfaq's key achievements?" },
        { label: "Contact Info", question: "How can I contact Ashfaq?" },
      ],
    };

    var NOT_FOUND_MESSAGE =
      "Information not found. Try one of the suggested questions above, or ask something else about Ashfaq.";

    var menuArea = document.getElementById("menu-area");
    var form = document.getElementById("chat-form");
    var input = document.getElementById("chat-input");
    var sendBtn = document.getElementById("chat-send-btn");
    var log = document.getElementById("chat-log");
    var errorEl = document.getElementById("chat-error");

    var busy = false;

    function setMenuButtonsDisabled(disabled) {
      var buttons = document.querySelectorAll(".menu-btn");
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].disabled = disabled;
      }
    }

    function renderMainMenu() {
      if (!menuArea) return;
      menuArea.innerHTML = "";

      var heading = document.createElement("div");
      heading.className = "menu-heading";
      heading.textContent = "Browse by category:";
      menuArea.appendChild(heading);

      var grid = document.createElement("div");
      grid.className = "menu-grid";

      Object.keys(CATEGORY_TREE).forEach(function (category) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "menu-btn category";
        btn.textContent = category;
        btn.disabled = busy;
        btn.addEventListener("click", function () {
          renderSubMenu(category);
        });
        grid.appendChild(btn);
      });

      menuArea.appendChild(grid);
    }

    function renderSubMenu(category) {
      if (!menuArea) return;
      menuArea.innerHTML = "";

      var heading = document.createElement("div");
      heading.className = "menu-heading";

      var back = document.createElement("button");
      back.type = "button";
      back.className = "back-btn";
      back.setAttribute("aria-label", "Back to categories");
      back.textContent = "←";
      back.addEventListener("click", renderMainMenu);
      heading.appendChild(back);

      var title = document.createElement("span");
      title.textContent = category;
      heading.appendChild(title);
      menuArea.appendChild(heading);

      var grid = document.createElement("div");
      grid.className = "menu-grid";

      var items = CATEGORY_TREE[category] || [];
      items.forEach(function (item) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "menu-btn";
        btn.textContent = item.label;
        btn.disabled = busy;
        btn.addEventListener("click", function () {
          askQuestion(item.question);
        });
        grid.appendChild(btn);
      });

      menuArea.appendChild(grid);
    }

    function appendMessage(text, sender, extraClass) {
      if (!log) return null;
      var msg = document.createElement("div");
      msg.className = "chat-msg " + sender + (extraClass ? " " + extraClass : "");
      msg.textContent = text;
      log.appendChild(msg);
      log.scrollTop = log.scrollHeight;
      return msg;
    }

    function askQuestion(question) {
      if (busy || !input || !sendBtn || !errorEl) return;
      busy = true;
      sendBtn.disabled = true;
      errorEl.textContent = "";
      setMenuButtonsDisabled(true);

      appendMessage(question, "user");
      var botMsg = appendMessage("Thinking…", "bot", "pending");
      var gotFirstToken = false;
      var full = "";

      // stream defaults to true server-side — this hits the SSE path in
      // chat.ts (the same one the docstring/PDF describes: "answers appear
      // to type themselves out"), instead of stream:false which makes the
      // browser wait for the entire answer to finish generating before
      // showing a single character. That full-wait behavior is correct for
      // the eval runner (easier to score a complete string) but was
      // wrongly being reused here for the live widget too — this is what
      // made every answer feel slow.
      fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question: question }),
      })
        .then(function (res) {
          var contentType = res.headers.get("Content-Type") || "";

          // The server only falls back to a plain JSON response when
          // something goes wrong before streaming could even start (bad
          // request, AI binding missing, model call threw immediately).
          if (contentType.indexOf("application/json") !== -1) {
            return res.json().catch(function () { return {}; }).then(function (body) {
              if (botMsg) botMsg.remove();
              if (res.ok && body.ok) {
                var answer = body.answer || NOT_FOUND_MESSAGE;
                appendMessage(answer, "bot", answer.indexOf("Information not found") === 0 ? "not-found" : "");
              } else {
                appendMessage(body.error || "Sorry, I couldn't answer that. Please try again.", "bot");
              }
            });
          }

          if (!res.body || !res.body.getReader) {
            if (botMsg) botMsg.remove();
            appendMessage("Could not reach the server. Please try again.", "bot");
            return;
          }

          var reader = res.body.getReader();
          var decoder = new TextDecoder();
          var buffer = "";

          function pump() {
            return reader.read().then(function (result) {
              if (result.done) return;

              buffer += decoder.decode(result.value, { stream: true });
              var lines = buffer.split("\n");
              buffer = lines.pop() || "";

              for (var i = 0; i < lines.length; i++) {
                var trimmed = lines[i].trim();
                if (trimmed.indexOf("data:") !== 0) continue;
                var payload = trimmed.slice(5).trim();
                if (payload === "[DONE]") continue;

                try {
                  var parsed = JSON.parse(payload);
                  if (parsed.response) {
                    if (!gotFirstToken) {
                      gotFirstToken = true;
                      if (botMsg) {
                        botMsg.classList.remove("pending");
                        botMsg.textContent = "";
                      }
                    }
                    full += parsed.response;
                    if (botMsg) {
                      botMsg.textContent = full;
                      log.scrollTop = log.scrollHeight;
                    }
                  }
                } catch (e) {
                  // ignore partial/non-JSON lines — they complete on the next chunk
                }
              }

              return pump();
            });
          }

          return pump().then(function () {
            if (full) {
              if (botMsg && full.indexOf("Information not found") === 0) {
                botMsg.classList.add("not-found");
              }
              return;
            }

            // Streaming produced zero usable chunks. This is almost always
            // a stream-shape parsing hiccup on our end, NOT the model
            // actually deciding the question is unanswerable — showing our
            // own "Information not found" fallback here would be a false
            // negative for a perfectly answerable question. Fall back to
            // the plain, reliable non-streaming request (the same one the
            // eval runner uses) before giving up.
            if (botMsg) {
              botMsg.textContent = "Thinking…";
              botMsg.classList.add("pending");
            }
            return fetch("/api/chat", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ question: question, stream: false }),
            })
              .then(function (res2) {
                return res2.json().catch(function () { return {}; });
              })
              .then(function (body2) {
                if (botMsg) botMsg.remove();
                var answer =
                  body2 && body2.ok
                    ? body2.answer || NOT_FOUND_MESSAGE
                    : (body2 && body2.error) || NOT_FOUND_MESSAGE;
                appendMessage(answer, "bot", answer.indexOf("Information not found") === 0 ? "not-found" : "");
              })
              .catch(function () {
                if (botMsg) botMsg.remove();
                appendMessage("Could not reach the server. Please try again.", "bot");
              });
          });
        })
        .catch(function (err) {
          if (botMsg) botMsg.remove();
          console.error("Chat error:", err);
          appendMessage("Could not reach the server. Please try again.", "bot");
        })
        .finally(function () {
          busy = false;
          sendBtn.disabled = false;
          input.value = "";
          input.focus();
          setMenuButtonsDisabled(false);
        });
    }

    if (form) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        var question = input ? input.value.trim() : "";
        if (!question) return;
        askQuestion(question);
      });
    }

    renderMainMenu();
  })();
</script>