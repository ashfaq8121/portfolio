---
// src/pages/ask.astro
// Adjust this import to match whatever layout your other pages use
// (contact.astro / about.astro etc.) — copy their exact import line if different.
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Ask About Me — Ashfaq ur Rahman" description="Browse questions about Ashfaq's background, grounded in his real résumé.">
  <section class="ask-section">
    <div class="ask-intro">
      <h1>Ask About Me</h1>
      <p>
        Pick a category below, then a question — I'll answer instantly from my real résumé.
        You can also type your own question if you don't see what you're looking for.
      </p>
      <a href="/ashfaq-ur-rahman-resume.pdf" download class="resume-download-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Résumé (PDF)
      </a>
    </div>

    <div class="chat-card">
      <div class="menu-area" id="menu-area"></div>

      <div id="chat-log" class="chat-log" aria-live="polite"></div>

      <form id="chat-form" class="chat-form">
        <input
          type="text"
          id="chat-input"
          class="chat-input"
          placeholder="Or type your own question..."
          autocomplete="off"
          maxlength="500"
          required
        />
        <button type="submit" class="btn btn-primary chat-send-btn" id="chat-send-btn">
          Ask
        </button>
      </form>
      <span class="chat-error" id="chat-error" role="alert" aria-live="polite"></span>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /*
   * is:global on purpose: the menu buttons and chat bubbles below are
   * created dynamically with document.createElement() in the <script> tag.
   * Astro's normal scoped styles only attach their scoping attribute to
   * elements present in this file's template at build time — anything
   * created later in plain JS never gets that attribute, so scoped rules
   * silently fail to match them (this is why buttons rendered as plain
   * unstyled text before). Going global avoids that trap. Class names
   * below are specific enough that collisions with other pages are very
   * unlikely, but rename them if you ever see a clash.
   */

  .ask-section {
    max-width: 720px;
    margin: 0 auto;
    /* max() guarantees clearance below a fixed/sticky nav regardless of
       its exact height, instead of guessing a fixed padding value. */
    padding-top: max(var(--space-8, 2rem), 6rem);
    padding-bottom: var(--space-8, 2rem);
    padding-left: var(--space-4, 1rem);
    padding-right: var(--space-4, 1rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-6, 1.5rem);
  }

  .ask-intro h1 { margin-bottom: var(--space-2, 0.5rem); }
  .ask-intro p { color: var(--color-text-secondary, #9a9a9a); line-height: 1.6; }

  .resume-download-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    margin-top: var(--space-3, 0.75rem);
    padding: var(--space-2, 0.5rem) var(--space-4, 1rem);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface, #1a1a1a);
    color: var(--color-text, #eaeaea);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .resume-download-btn:hover {
    border-color: var(--color-accent, #6366f1);
    color: var(--color-accent, #6366f1);
  }

  .chat-card {
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface, #1a1a1a);
    padding: var(--space-4, 1rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  /* ── Category / subcategory menu ── */
  .menu-area {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  .menu-heading {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-text, #eaeaea);
  }

  .back-btn {
    background: none;
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text, #eaeaea);
    cursor: pointer;
    flex-shrink: 0;
  }

  .back-btn:hover { border-color: var(--color-accent, #6366f1); color: var(--color-accent, #6366f1); }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-2, 0.5rem);
  }

  .menu-btn {
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    padding: var(--space-3, 0.75rem);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    color: var(--color-text, #eaeaea);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }

  .menu-btn:hover:not(:disabled) {
    border-color: var(--color-accent, #6366f1);
    color: var(--color-accent, #6366f1);
  }

  .menu-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .menu-btn.category {
    font-weight: 600;
    text-align: center;
    padding: var(--space-4, 1rem);
  }

  /* ── Chat log ── */
  .chat-log {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    min-height: 8rem;
    max-height: 24rem;
    overflow-y: auto;
    padding: var(--space-2, 0.5rem);
  }

  .chat-msg {
    max-width: 85%;
    padding: var(--space-3, 0.75rem);
    border-radius: var(--radius-lg, 12px);
    line-height: 1.5;
    font-size: var(--text-sm, 0.875rem);
    white-space: pre-wrap;
  }

  .chat-msg.user {
    align-self: flex-end;
    background: var(--color-accent, #6366f1);
    color: #ffffff;
  }

  .chat-msg.bot {
    align-self: flex-start;
    background: var(--color-bg, #111);
    color: var(--color-text, #eaeaea);
    border: 1px solid var(--color-border, #333);
  }

  .chat-msg.bot.not-found {
    background: transparent;
    border-style: dashed;
    color: var(--color-text-secondary, #9a9a9a);
    font-style: italic;
  }

  .chat-form {
    display: flex;
    gap: var(--space-2, 0.5rem);
  }

  .chat-input {
    flex: 1;
    padding: var(--space-3, 0.75rem);
    border: 1px solid var(--color-border, #333);
    border-radius: var(--radius-lg, 12px);
    background: var(--color-bg, #111);
    color: var(--color-text, #eaeaea);
    font-size: var(--text-sm, 0.875rem);
  }

  .chat-send-btn { white-space: nowrap; }

  .chat-error {
    color: #f87171;
    font-size: var(--text-sm, 0.875rem);
  }

  /* ── Mobile responsiveness ── */
  @media (max-width: 480px) {
    .ask-section {
      padding-top: max(var(--space-6, 1.5rem), 5rem);
      gap: var(--space-4, 1rem);
    }

    .menu-grid {
      grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
      gap: var(--space-2, 0.5rem);
    }

    .menu-btn { padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem); }
    .menu-btn.category { padding: var(--space-3, 0.75rem); }

    /* Stack input + button instead of squeezing them side by side —
       keeps both comfortably tappable on a phone screen. */
    .chat-form {
      flex-direction: column;
    }

    .chat-send-btn {
      width: 100%;
    }

    .chat-msg {
      max-width: 100%;
    }

    .chat-log {
      max-height: 20rem;
    }

    .resume-download-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script nonce={Astro.locals.nonce}>
  // ── Category tree ──────────────────────────────────────────────────────
  // Edit labels/questions here to match resume-context.ts if your resume
  // content ever changes. Each leaf's "question" is sent to /api/chat
  // exactly as if the visitor had typed it — same code path, same guardrails.
  type Leaf = { label: string; question: string };
  const CATEGORY_TREE: Record<string, Leaf[]> = {
    "Education": [
      { label: "B.Tech (Computer Science)", question: "Tell me about Ashfaq's B.Tech degree." },
      { label: "Intermediate (12th Grade)", question: "What did Ashfaq score in his Intermediate (12th grade)?" },
      { label: "SSC (10th Grade)", question: "What did Ashfaq score in his SSC (10th grade)?" },
    ],
    "Skills": [
      { label: "Programming Languages", question: "What programming languages does Ashfaq know?" },
      { label: "BI & Dashboard Tools", question: "What BI or dashboard tools has Ashfaq used?" },
      { label: "Data Analysis Skills", question: "What data analysis skills does Ashfaq have?" },
      { label: "Web Technologies", question: "What web technologies does Ashfaq know?" },
    ],
    "Projects": [
      { label: "Superstore Sales Analysis", question: "Tell me about Ashfaq's Superstore Sales Analysis project." },
      { label: "NYC Taxi Data Dashboard", question: "Tell me about Ashfaq's NYC taxi project." },
      { label: "HR Attrition Analysis", question: "Tell me about Ashfaq's HR Attrition Analysis project." },
    ],
    "Certifications": [
      { label: "Google Analytics", question: "Tell me about Ashfaq's Google Analytics certification." },
      { label: "Power BI (Microsoft Learn)", question: "Tell me about Ashfaq's Power BI certification." },
      { label: "Python Internship Certificate", question: "Tell me about Ashfaq's Python programming internship certification." },
    ],
    "Other": [
      { label: "Internships", question: "What internships has Ashfaq completed?" },
      { label: "Achievements", question: "What are Ashfaq's key achievements?" },
      { label: "Contact Info", question: "How can I contact Ashfaq?" },
    ],
  };

  // Must match NOT_FOUND_MESSAGE exported from src/lib/chat-system-prompt.ts —
  // duplicated here since this script runs in the browser and can't import
  // server-side modules. If you change one, change the other.
  const NOT_FOUND_MESSAGE =
    "Information not found. Try one of the suggested questions above, or ask something else about Ashfaq.";

  const menuArea = document.getElementById("menu-area") as HTMLDivElement;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const input = document.getElementById("chat-input") as HTMLInputElement;
  const sendBtn = document.getElementById("chat-send-btn") as HTMLButtonElement;
  const log = document.getElementById("chat-log") as HTMLDivElement;
  const errorEl = document.getElementById("chat-error") as HTMLSpanElement;

  let busy = false; // disables menu/chip clicks while a question is in flight

  function renderMainMenu() {
    menuArea.innerHTML = "";

    const heading = document.createElement("div");
    heading.className = "menu-heading";
    heading.textContent = "Browse by category:";
    menuArea.appendChild(heading);

    const grid = document.createElement("div");
    grid.className = "menu-grid";
    for (const category of Object.keys(CATEGORY_TREE)) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "menu-btn category";
      btn.textContent = category;
      btn.disabled = busy;
      btn.addEventListener("click", () => renderSubMenu(category));
      grid.appendChild(btn);
    }
    menuArea.appendChild(grid);
  }

  function renderSubMenu(category: string) {
    menuArea.innerHTML = "";

    const heading = document.createElement("div");
    heading.className = "menu-heading";

    const back = document.createElement("button");
    back.type = "button";
    back.className = "back-btn";
    back.setAttribute("aria-label", "Back to categories");
    back.textContent = "←";
    back.addEventListener("click", renderMainMenu);
    heading.appendChild(back);

    const label = document.createElement("span");
    label.textContent = category;
    heading.appendChild(label);

    menuArea.appendChild(heading);

    const grid = document.createElement("div");
    grid.className = "menu-grid";
    for (const leaf of CATEGORY_TREE[category]) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "menu-btn";
      btn.textContent = leaf.label;
      btn.disabled = busy;
      btn.addEventListener("click", () => {
        if (busy) return;
        askQuestion(leaf.question);
      });
      grid.appendChild(btn);
    }
    menuArea.appendChild(grid);
  }

  renderMainMenu();

  function addMessage(text: string, who: "user" | "bot"): HTMLDivElement {
    const el = document.createElement("div");
    el.className = `chat-msg ${who}`;
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
    return el;
  }

  function setBusy(value: boolean) {
    busy = value;
    sendBtn.disabled = value;
    input.disabled = value;
    menuArea.querySelectorAll<HTMLButtonElement>("button").forEach((b) => {
      b.disabled = value;
    });
  }

  async function askQuestion(question: string) {
    addMessage(question, "user");
    const botEl = addMessage("", "bot");
    errorEl.textContent = "";
    setBusy(true);

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question, stream: true }),
        credentials: "same-origin",
      });

      if (!res.ok || !res.body) {
        const body = await res.json().catch(() => ({}));
        errorEl.textContent = body.error ?? "Could not get an answer. Please try again.";
        botEl.remove();
        return;
      }

      // Workers AI streams Server-Sent-Events lines: `data: {"response":"token"}`
      // ending with `data: [DONE]`. Parse incrementally as chunks arrive.
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      let answer = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });

        const lines = buffer.split("\n");
        buffer = lines.pop() ?? "";

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed.startsWith("data:")) continue;
          const payload = trimmed.slice(5).trim();
          if (payload === "[DONE]") continue;
          try {
            const parsed = JSON.parse(payload);
            if (typeof parsed.response === "string") {
              answer += parsed.response;
              botEl.textContent = answer;
              log.scrollTop = log.scrollHeight;
            }
          } catch {
            // ignore partial/non-JSON lines
          }
        }
      }

      if (!answer) {
        botEl.textContent = NOT_FOUND_MESSAGE;
        botEl.classList.add("not-found");
      } else if (answer.trim() === NOT_FOUND_MESSAGE) {
        botEl.classList.add("not-found");
      }
    } catch {
      errorEl.textContent = "Could not reach the server. Please check your connection.";
      botEl.remove();
    } finally {
      setBusy(false);
      input.focus();
    }
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (busy) return;
    const question = input.value.trim();
    if (!question) return;
    input.value = "";
    askQuestion(question);
  });
</script>