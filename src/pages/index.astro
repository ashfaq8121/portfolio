---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Home"
  description="Ashfaq Ur Rahman is a recent Computer Science Engineering graduate focused on web development, clean UI/UX, and data analysis."
>
  <section class="hero container" aria-label="Introduction">
    <div class="hero-content">
    
      <p class="hero-label">Hello, I'm</p>
      <h1 class="hero-name">Ashfaq Ur Rahman</h1>
      <p class="hero-desc">
        I am a recent Computer Science Engineering graduate based in Khammam.
        I build responsive web interfaces, create user-focused UI/UX,
        and use data analysis to turn raw information into meaningful business insights.
      </p>

      <div class="hero-actions">
        <a href={`${base}/projects`} class="btn btn-primary">See my work</a>
        <a href={`${base}/contact`} class="btn btn-outline">Get in touch</a>
      </div>
    </div>

    <aside class="hero-links" aria-label="Social links">
      <a
        href="https://github.com/ashfaq8121"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-social-link"
      >
        GitHub &nearr;
      </a>
      <a
        href="https://linkedin.com/in/ashfaq-ur-rahman-54832027b"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-social-link"
      >
        LinkedIn &nearr;
      </a>
    </aside>
  </section>

  <!-- Skills section moved from About page -->
  <section class="container skills-section" aria-labelledby="skills-title">
    <div class="section-header">
      <p class="hero-label">What I work with</p>
      <h2 id="skills-title">Skills</h2>
    </div>

    <div class="skills-grid">
      <div class="skill-group">
        <h3 class="skill-group-title">Frontend</h3>
        <div class="skill-tags">
          <span class="skill-tag">HTML</span>
          <span class="skill-tag">CSS</span>
          <span class="skill-tag">JavaScript</span>
          <span class="skill-tag">Responsive Web Design</span>
          <span class="skill-tag">Clean UI/UX Design</span>
        </div>
      </div>

      <div class="skill-group">
        <h3 class="skill-group-title">Data & Analytics</h3>
        <div class="skill-tags">
          <span class="skill-tag">Python</span>
          <span class="skill-tag">Pandas</span>
          <span class="skill-tag">NumPy</span>
          <span class="skill-tag">Power BI</span>
          <span class="skill-tag">SQL</span>
          <span class="skill-tag">Excel</span>
          <span class="skill-tag">Data Analysis</span>
          <span class="skill-tag">Dashboard Building</span>
        </div>
      </div>

      <div class="skill-group">
        <h3 class="skill-group-title">Tools & Practices</h3>
        <div class="skill-tags">
          <span class="skill-tag">Git & GitHub</span>
          <span class="skill-tag">Cloudflare</span>
          <span class="skill-tag">Problem Solving</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-8);
    padding-top: calc(var(--nav-height) + var(--space-10));
    padding-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .hero {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-12);
      padding-top: calc(var(--nav-height) + var(--space-16));
      padding-bottom: var(--space-16);
    }
  }

  .hero-content {
    max-width: 42rem;
    width: 100%;
  }

  .hero-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .hero-name {
    font-size: clamp(2.4rem, 11vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
    color: var(--color-text);
    overflow-wrap: break-word;
  }

  .hero-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 44ch;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-desc {
      font-size: var(--text-lg);
      margin-bottom: var(--space-8);
    }
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero-actions .btn {
    width: 100%;
    justify-content: center;
  }

  @media (min-width: 480px) {
    .hero-actions .btn {
      width: auto;
    }
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-shrink: 0;
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero-links {
      width: auto;
      align-items: flex-end;
    }
  }

  .hero-social-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .hero-social-link:hover {
    color: var(--color-accent);
  }

  /* Skills section */
  .skills-section {
    padding-bottom: var(--space-24);
    padding-top: var(--space-4);
  }

  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-header h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .skill-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .skill-group-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skill-tag {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border-radius: 9999px;
    background: var(--color-surface-offset, rgba(0, 0, 0, 0.05));
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.4;
    border: 1px solid var(--color-border);
  }
</style>
